# PostgreSQL database used by FastAPI for Google reviews.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bhaiyya_reviews

# Google Business Profile Reviews API OAuth credentials.
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REFRESH_TOKEN=your-google-refresh-token

# Numeric IDs from Google Business Profile APIs.
GOOGLE_ACCOUNT_ID=your-account-id
GOOGLE_LOCATION_ID=your-location-id

# Background sync settings.
GOOGLE_REVIEWS_ENABLED=true
GOOGLE_SYNC_INTERVAL_SECONDS=3600

# Optional: set this to protect POST /api/reviews/sync.
SYNC_API_KEY=
